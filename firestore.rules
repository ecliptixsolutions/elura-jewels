rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminEmail() {
      return signedIn()
        && request.auth.token.email in [
          'padariyaarth@gmail.com',
          'info.elurajewels@gmail.com',
          'services@ecliptixsolutions.com'
        ];
    }

    match /cms/{document=**} {
      allow read: if true;
      allow write: if adminEmail();
    }

    match /heroBanners/{document=**} {
      allow read: if true;
      allow write: if adminEmail();
    }

    match /users/{userId} {
      allow read, update: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
